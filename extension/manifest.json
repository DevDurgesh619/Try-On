{
  "manifest_version": 3,
  "name": "TryOn",
  "version": "0.0.2",
  "description": "See how clothes, hairstyles, and beards look on you in one click while shopping.",
  "action": {
    "default_title": "TRY · ON",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "src/background/index.ts",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "contextMenus",
    "activeTab",
    "scripting",
    "tabs",
    "identity"
  ],
  "oauth2": {
    "client_id": "375655762689-1nstar9b0ug279lvptrftsl6fldjarti.apps.googleusercontent.com",
    "scopes": [
      "openid",
      "email"
    ]
  },
  "host_permissions": [
    "https://*.myntra.com/*",
    "https://*.amazon.in/*",
    "https://*.flipkart.com/*",
    "https://*.pinterest.com/*",
    "https://*.pinimg.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "https://*.workers.dev/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.myntra.com/*",
        "https://*.amazon.in/*",
        "https://*.flipkart.com/*",
        "https://*.pinterest.com/*"
      ],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle"
    }
  ]
}
